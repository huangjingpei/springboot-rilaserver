server {
	listen 8081;
	server_name _;

	# 静态文件服务
	location /admin/ {
		# 注意：请确保此路径与服务器上实际的 dist 目录路径一致
		# 如果是 Linux 服务器，通常是类似 /var/www/admin-ui/dist/ 的路径
		alias "d:/spring-boot-user-registration-and-Login/admin-ui/dist/";
		index index.html;
		try_files $uri $uri/ /admin/index.html;
	}

